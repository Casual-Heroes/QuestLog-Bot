# WardenBot Environment Variables
# In production, place your actual values at /etc/casual-heroes/warden.env
# (owner: root, group: www-data, mode: 640)
# For local development, copy this file to .env and fill in your values.

# ─── Discord Bot ──────────────────────────────────────────────────────────────
# Get from: discord.com/developers/applications -> Your App -> Bot -> Token
WARDEN_BOT_TOKEN=

# Discord OAuth2 (for web dashboard login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://dashboard.yourdomain.com/auth/discord/callback

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
# Use Unix socket for local connections (faster and more reliable)
DB_SOCKET=/var/run/mysqld/mysqld.sock

# TCP connection (use instead of socket for remote MySQL)
#DB_HOST=localhost
#DB_PORT=3306

DB_USERNAME=
DB_PASSWORD=
DB_NAME=warden

# Show SQL queries in console? (only enable when debugging)
DB_ECHO=false

# ─── Django Web App Database (for shared models with ch-webserver) ────────────
DJANGO_DB_NAME=questlog_web
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=3306

# ─── Bot API Authentication ───────────────────────────────────────────────────
# Token used by ch-webserver to authenticate requests to the bot's internal API
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DISCORD_BOT_API_TOKEN=

# ─── Twitch / IGDB API (Game Discovery) ──────────────────────────────────────
# Get credentials at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ─── Bot Owner & Access Control ──────────────────────────────────────────────
# Discord user ID of the bot owner (enables /emergency commands)
BOT_OWNER_ID=
# Comma-separated Discord user IDs allowed to approve Discovery Network communities
DISCOVERY_APPROVERS=

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=production

# For development: restrict slash commands to one guild for faster sync
# DEBUG_GUILD_ID=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_PATH=.
LOG_LEVEL=INFO

# ─── Emergency Kill Switch ────────────────────────────────────────────────────
# Path to the Django maintenance flag file (must match ch-webserver config)
MAINTENANCE_FLAG_PATH=/srv/ch-webserver/.maintenance
# systemd service names (adjust if yours differ)
EMERGENCY_WEB_SERVICE=casualheroes
EMERGENCY_MATRIX_SERVICE=matrix-synapse
# Optional: Discord channel ID to log emergency actions (0 to disable)
EMERGENCY_AUDIT_CHANNEL_ID=0

# ─── AMP Game Server Panel (optional) ────────────────────────────────────────
# AMP_URL=http://your-amp-host:8080
# AMP_USER=
# AMP_PASSWORD=
